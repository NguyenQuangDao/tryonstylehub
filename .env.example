# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# JWT Secret (use a strong random string)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# OpenAI API
OPENAI_API_KEY="sk-..."

# Replicate API (for AI try-on)
REPLICATE_API_TOKEN="r8_..."

# ===========================================
# PAYMENT GATEWAY CREDENTIALS
# ===========================================

# Stripe (International Credit/Debit Cards)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# PayPal (International)
# Get from: https://developer.paypal.com/
PAYPAL_CLIENT_ID="..."
PAYPAL_CLIENT_SECRET="..."
PAYPAL_API_BASE="https://api-m.sandbox.paypal.com"  # Use https://api-m.paypal.com for production

# MoMo (Vietnam E-wallet)
# Get from: https://developers.momo.vn/
MOMO_PARTNER_CODE="..."
MOMO_ACCESS_KEY="..."
MOMO_SECRET_KEY="..."
MOMO_ENDPOINT="https://test-payment.momo.vn/v2/gateway/api/create"  # Use production URL for live

# VNPay (Vietnam Payment Gateway)
# Get from: https://sandbox.vnpayment.vn/
VNPAY_TMN_CODE="..."
VNPAY_HASH_SECRET="..."
VNPAY_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"  # Use production URL for live


# ===========================================
# NOTES
# ===========================================
# 
# 1. For DEVELOPMENT/TESTING:
#    - Use sandbox/test credentials
#    - Stripe: Use test API keys (sk_test_, pk_test_)
#    - PayPal: Use sandbox environment
#    - MoMo/VNPay/ZaloPay: Use test credentials from respective developer portals
#
# 2. For PRODUCTION:
#    - Replace ALL test credentials with live credentials
#    - Update endpoint URLs to production URLs
#    - Enable webhook URLs for payment confirmations
#
# 3. SECURITY:
#    - NEVER commit .env file to version control
#    - Keep this file in .gitignore
#    - Use strong random strings for secrets
#    - Rotate credentials regularly
